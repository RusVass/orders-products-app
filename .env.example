# Optional overrides for docker-compose.yml. Copy to .env in this same
# directory (repo root) if you need different ports/URLs - Compose loads
# it automatically. Not required for `docker compose up --build`: the
# values below are already the defaults baked into docker-compose.yml.
#
# Application-level env vars (client/.env.example, server/.env.example)
# are separate and unaffected by this file.

PORT=4500
CLIENT_PORT=8080
CLIENT_URL=http://localhost:8080
VITE_SOCKET_URL=http://localhost:4500
